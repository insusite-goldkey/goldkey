# ─────────────────────────────────────────────────────────────────────────────
# 골드키 CRM — 환경 변수 템플릿
#
# 사용법:
#   1. 이 파일을 복사하여 .env 로 저장
#   2. 아래 값들을 실제 Firebase 프로젝트 값으로 교체
#   3. .env 파일은 절대 Git에 커밋하지 말 것 (.gitignore에 등록됨)
#
# Firebase 값 확인 위치:
#   https://console.firebase.google.com
#   → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정 및 구성
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase 프로젝트 식별 ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=goldkey-crm
FIREBASE_APP_ID=1:000000000000:android:xxxxxxxxxxxxxxxx

# ── Firestore 지역 (asia-northeast3 = 서울) ──────────────────────────────────
FIREBASE_REGION=asia-northeast3

# ── Firebase Storage (의료문서 이미지 업로드용) ───────────────────────────────
FIREBASE_STORAGE_BUCKET=goldkey-crm.appspot.com

# ── Firebase Cloud Messaging (푸시 알림) — 선택 ──────────────────────────────
FIREBASE_MESSAGING_SENDER_ID=000000000000

# ── AI 분석 엔진 (Gemini API) ────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_API_KEY_HERE

# ── 앱 환경 ──────────────────────────────────────────────────────────────────
# development | staging | production
APP_ENV=development

# ── 기능 플래그 ───────────────────────────────────────────────────────────────
# Firebase 연동 활성화 여부 (false = 로컬 Zustand 전용 모드)
ENABLE_FIREBASE=true
# AI 분석 기능 활성화 여부
ENABLE_AI_ANALYSIS=true
# 데이터 내보내기(CSV) 기능 활성화 여부
ENABLE_EXPORT=true
