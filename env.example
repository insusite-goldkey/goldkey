# ==========================================================================
# Goldkey AI Master Lab. — 환경변수 설정 예시 (env.example)
# ==========================================================================
# 사용 방법:
#   1. 이 파일을 복사하여 .streamlit/secrets.toml 로 저장하세요.
#   2. YOUR_KEY_HERE 부분에 실제 API 키를 입력하세요.
#   3. .streamlit/secrets.toml 은 절대 Git에 커밋하지 마세요.
#
# HuggingFace Spaces 배포 시:
#   Settings → Repository secrets 에 아래 키를 직접 등록하세요.
#   secrets.toml 파일 없이도 st.secrets 로 자동 로드됩니다.
# ==========================================================================

# ── [GP240조] 카카오 알림톡 (비즈메시지 API) ──────────────────────────────
# 발급처: https://developers.kakao.com → 비즈메시지 → 앱 키
KAKAO_API_KEY     = "YOUR_KAKAO_API_KEY_HERE"

# 카카오 플러스친구 채널 발신 키
# 발급처: https://bizmessage.kakao.com → 발신 프로필 → 채널 키
KAKAO_SENDER_KEY  = "YOUR_KAKAO_SENDER_KEY_HERE"

# 알림톡 템플릿 코드 (사전 심사·등록 필요)
# 기본값: goldkey_report_v1 (변수: #{title}, #{content})
KAKAO_TEMPLATE_ID = "goldkey_report_v1"

# ── [GP240조] SMS 발송 (솔라API — Solapi) ─────────────────────────────────
# 발급처: https://console.solapi.com → API Key 관리
SMS_API_KEY    = "YOUR_SOLAPI_API_KEY_HERE"
SMS_API_SECRET = "YOUR_SOLAPI_API_SECRET_HERE"

# 사전 등록된 발신번호 (Solapi 콘솔에서 번호 인증 필수)
SMS_SENDER_NUM = "010-XXXX-XXXX"

# ── AI / DB ───────────────────────────────────────────────────────────────
# Google Gemini API 키
# 발급처: https://aistudio.google.com → API Keys
GOOGLE_API_KEY = "YOUR_GOOGLE_API_KEY_HERE"

# Supabase 프로젝트 URL 및 anon 키
# 발급처: https://app.supabase.com → Project Settings → API
SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
SUPABASE_KEY = "YOUR_SUPABASE_ANON_KEY_HERE"

# ── 선택 사항 ─────────────────────────────────────────────────────────────
# Hybrid RAG 백엔드 URL (FastAPI 서버 — 없으면 RAG 기능 비활성)
HYBRID_BACKEND_URL = ""

# ==========================================================================
# .streamlit/secrets.toml 변환 예시:
#
# [default]
# KAKAO_API_KEY     = "YOUR_KAKAO_API_KEY_HERE"
# KAKAO_SENDER_KEY  = "YOUR_KAKAO_SENDER_KEY_HERE"
# KAKAO_TEMPLATE_ID = "goldkey_report_v1"
# SMS_API_KEY       = "YOUR_SOLAPI_API_KEY_HERE"
# SMS_API_SECRET    = "YOUR_SOLAPI_API_SECRET_HERE"
# SMS_SENDER_NUM    = "010-XXXX-XXXX"
# GOOGLE_API_KEY    = "YOUR_GOOGLE_API_KEY_HERE"
# SUPABASE_URL      = "https://YOUR_PROJECT.supabase.co"
# SUPABASE_KEY      = "YOUR_SUPABASE_ANON_KEY_HERE"
# ==========================================================================
