# ==========================================================================
# Goldkey AI Master Lab. — 환경변수 설정 예시 (env.example)
# ==========================================================================
# ★ 배포 환경: Google Cloud Run (asia-northeast3)
# ★ 비밀값 관리: GitHub Repository Secrets → Cloud Run --set-env-vars 자동 주입
#
# 등록 방법 (GitHub → Cloud Run 파이프라인):
#   1. GitHub 저장소 → Settings → Secrets and variables → Actions
#   2. "New repository secret" 으로 아래 키를 하나씩 등록
#   3. git push 시 deploy-cloudrun.yml이 자동으로 Cloud Run에 환경변수 주입
#   → secrets.toml 파일 불필요, 코드에 키 하드코딩 절대 금지
#
# 로컬 개발 전용 (Cloud Run 배포와 무관):
#   .streamlit/secrets.toml 에 아래 키 입력 후 streamlit run app.py 실행
#   (.streamlit/secrets.toml 은 .gitignore에 포함 — 절대 커밋 금지)
# ==========================================================================

# ── [GP240조] 카카오 알림톡 (비즈메시지 API) ──────────────────────────────
# 발급처: https://developers.kakao.com → 비즈메시지 → 앱 키
KAKAO_API_KEY     = "YOUR_KAKAO_API_KEY_HERE"

# 카카오 플러스친구 채널 발신 키
# 발급처: https://bizmessage.kakao.com → 발신 프로필 → 채널 키
KAKAO_SENDER_KEY  = "YOUR_KAKAO_SENDER_KEY_HERE"

# 알림톡 템플릿 코드 (사전 심사·등록 필요)
# 기본값: goldkey_report_v1 (변수: #{title}, #{content})
KAKAO_TEMPLATE_ID = "goldkey_report_v1"

# ── [GP240조] SMS 발송 (솔라API — Solapi) ─────────────────────────────────
# 발급처: https://console.solapi.com → API Key 관리
SMS_API_KEY    = "YOUR_SOLAPI_API_KEY_HERE"
SMS_API_SECRET = "YOUR_SOLAPI_API_SECRET_HERE"

# 사전 등록된 발신번호 (Solapi 콘솔에서 번호 인증 필수)
SMS_SENDER_NUM = "010-XXXX-XXXX"

# ── AI / DB ───────────────────────────────────────────────────────────────
# Google Gemini API 키
# 발급처: https://aistudio.google.com → API Keys
GOOGLE_API_KEY = "YOUR_GOOGLE_API_KEY_HERE"

# Supabase 프로젝트 URL 및 anon 키
# 발급처: https://app.supabase.com → Project Settings → API
SUPABASE_URL = "https://YOUR_PROJECT.supabase.co"
SUPABASE_KEY = "YOUR_SUPABASE_ANON_KEY_HERE"

# ── 선택 사항 ─────────────────────────────────────────────────────────────
# Hybrid RAG 백엔드 URL (FastAPI 서버 — 없으면 RAG 기능 비활성)
HYBRID_BACKEND_URL = ""

# ==========================================================================
# GitHub Repository Secrets 등록 목록 (Cloud Run 배포용):
#   → github.com/insusite-goldkey/goldkey → Settings → Secrets → Actions
#
# [기존 등록 완료]
#   GCP_SA_KEY                 Google Cloud 서비스 계정 JSON
#   GEMINI_API_KEY             Google Gemini AI API 키
#   SUPABASE_URL               Supabase 프로젝트 URL
#   SUPABASE_SERVICE_ROLE_KEY  Supabase Service Role Key
#   ADMIN_CODE                 관리자 코드
#   MASTER_CODE                마스터 코드
#   ENCRYPTION_KEY             데이터 암호화 키
#   GCS_BUCKET_NAME            Google Cloud Storage 버킷명
#   FINLIFE_API_KEY            금융감독원 금융상품 API 키
#
# [추가 필요 — 카카오/SMS 발송 활성화]
#   KAKAO_API_KEY              카카오 비즈메시지 App Key
#   KAKAO_SENDER_KEY           카카오 플러스친구 채널 Key
#   KAKAO_TEMPLATE_ID          알림톡 템플릿 코드 (미등록 시 기본값 사용)
#   SMS_API_KEY                솔라API Key
#   SMS_API_SECRET             솔라API Secret
#   SMS_SENDER_NUM             발신번호 (사전 등록 필수)
#
# 위 6개 키 등록 후 git push → GitHub Actions 자동 배포 시 Cloud Run에 즉시 반영됨
# ==========================================================================
